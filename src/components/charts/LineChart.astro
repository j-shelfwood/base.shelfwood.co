---
/**
 * Lightweight SVG line chart — no JS library dependency.
 * Renders server-side, can be hydrated client-side by replacing via fetch.
 */

interface DataPoint {
  time: string;
  value: number;
}

interface Props {
  data: DataPoint[];
  colour?: string;
  height?: number;
  suffix?: string;
  id?: string;
}

const {
  data,
  colour = 'var(--color-mc-diamond)',
  height = 80,
  suffix = '',
  id,
} = Astro.props;

const WIDTH = 400;
const HEIGHT = height;
const PAD = 4;

function buildPath(points: DataPoint[]): string {
  if (points.length === 0) return '';
  const values = points.map(p => p.value);
  const minV = Math.min(...values);
  const maxV = Math.max(...values);
  const range = maxV - minV || 1;

  const coords = points.map((p, i) => {
    const x = PAD + (i / (points.length - 1 || 1)) * (WIDTH - PAD * 2);
    const y = PAD + (1 - (p.value - minV) / range) * (HEIGHT - PAD * 2);
    return `${x},${y}`;
  });

  return `M ${coords.join(' L ')}`;
}

function buildFill(points: DataPoint[]): string {
  if (points.length === 0) return '';
  const path = buildPath(points);
  const lastX = PAD + (WIDTH - PAD * 2);
  return `${path} L ${lastX},${HEIGHT - PAD} L ${PAD},${HEIGHT - PAD} Z`;
}

const path = buildPath(data);
const fill = buildFill(data);
const lastValue = data.at(-1)?.value ?? null;
const maxValue = data.length > 0 ? Math.max(...data.map(p => p.value)) : null;
const minValue = data.length > 0 ? Math.min(...data.map(p => p.value)) : null;
---

<div class="flex flex-col gap-1" id={id}>
  {data.length > 0 ? (
    <svg
      viewBox={`0 0 ${WIDTH} ${HEIGHT}`}
      class="w-full"
      style={`height: ${HEIGHT}px`}
      aria-hidden="true"
    >
      <!-- Fill -->
      {fill && (
        <path
          d={fill}
          fill={colour}
          opacity="0.1"
        />
      )}
      <!-- Line -->
      {path && (
        <path
          d={path}
          fill="none"
          stroke={colour}
          stroke-width="2"
          stroke-linejoin="round"
          stroke-linecap="round"
        />
      )}
    </svg>
    <div class="flex justify-between font-mc text-xs text-mc-muted">
      <span>{minValue?.toFixed(1)}{suffix}</span>
      <span style={`color: ${colour}`}>{lastValue?.toFixed(1)}{suffix}</span>
      <span>{maxValue?.toFixed(1)}{suffix}</span>
    </div>
  ) : (
    <div
      class="flex items-center justify-center font-mc text-xs text-mc-muted"
      style={`height: ${HEIGHT}px`}
    >
      NO DATA
    </div>
  )}
</div>
