---
import Layout from '@/layouts/Layout.astro';
import Panel from '@/components/mc/Panel.astro';
import StatCard from '@/components/mc/StatCard.astro';
import ProgressBar from '@/components/mc/ProgressBar.astro';
import { machineSummary, machineTypes, mekanismMachines, miMachineGroups } from '@/lib/queries';

const [summaryRes, typesRes, mekanismRes, miRes] = await Promise.allSettled([
  machineSummary(),
  machineTypes(),
  mekanismMachines(),
  miMachineGroups(),
]);

const summary = summaryRes.status === 'fulfilled' ? summaryRes.value : null;
const types = typesRes.status === 'fulfilled' ? typesRes.value : [];
const mekanismMachineList = mekanismRes.status === 'fulfilled' ? mekanismRes.value : [];
const miGroups = miRes.status === 'fulfilled' ? miRes.value : [];
---

<Layout title="MC Base — Machines">
  <div class="mb-6">
    <h1 class="font-mc text-mc-white text-xl">MACHINES</h1>
    <p class="font-mc text-xs text-mc-muted mt-1">MEKANISM ACTIVITY · MI MACHINE GROUPS</p>
  </div>

  <!-- Summary stats -->
  <div class="grid grid-cols-3 gap-3 mb-6">
    <StatCard
      label="Active"
      value={summary?.active_machines ?? '—'}
      colour="emerald"
      id="stat-active"
    />
    <StatCard
      label="Total"
      value={summary?.total_machines ?? '—'}
      colour="white"
      id="stat-total"
    />
    <StatCard
      label="Active %"
      value={summary ? summary.active_percent.toFixed(1) + '%' : '—'}
      colour={summary && summary.active_percent > 50 ? 'emerald' : 'copper'}
      id="stat-active-pct"
    />
  </div>

  <!-- Mekanism machines -->
  <Panel title="MEKANISM MACHINES" raised noPadding class="mb-6">
    <div id="mek-list">
      {mekanismMachineList.length === 0 && (
        <p class="font-mc text-xs text-mc-muted px-4 py-6">No Mekanism machine data</p>
      )}
      {mekanismMachineList.map(m => (
        <div class="px-4 py-3 border-b border-mc-cobble/50 last:border-0">
          <div class="flex items-center justify-between mb-2">
            <div class="flex flex-col gap-0.5">
              <span class="font-mc text-xs text-mc-white capitalize">{m.name}</span>
              <span class="font-mc text-xs text-mc-muted">{m.type}</span>
            </div>
            <span class:list={[
              'font-mc text-xs px-2 py-0.5',
              m.active ? 'text-mc-emerald' : 'text-mc-muted'
            ]}>
              {m.active ? 'ACTIVE' : 'IDLE'}
            </span>
          </div>
          {m.active && (
            <div class="flex flex-col gap-1.5">
              <ProgressBar
                value={m.progress_percent}
                colour="amethyst"
                label={`Progress: ${m.progress}/${m.progress_total}`}
                showPercent
              />
              <ProgressBar
                value={m.energy_percent}
                colour="gold"
                label="Energy"
                showPercent
              />
            </div>
          )}
          {!m.active && (
            <ProgressBar
              value={m.energy_percent}
              colour="gold"
              label="Energy"
              showPercent
            />
          )}
        </div>
      ))}
    </div>
  </Panel>

  <!-- MI machine groups + type breakdown -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
    <Panel title="MODERN INDUSTRIALIZATION" raised noPadding>
      <div id="mi-list">
        {miGroups.length === 0 && (
          <p class="font-mc text-xs text-mc-muted px-4 py-6">No MI machine data</p>
        )}
        {miGroups.map(g => (
          <div class="flex items-center justify-between px-4 py-2 border-b border-mc-cobble/50 last:border-0">
            <span class="font-mc text-xs text-mc-white capitalize">{g.label}</span>
            <span class="font-mc text-xs text-mc-diamond">{g.count}×</span>
          </div>
        ))}
      </div>
    </Panel>

    <Panel title="BY TYPE" raised>
      <div class="flex flex-col gap-3" id="type-table">
        {types.length === 0 && (
          <span class="font-mc text-xs text-mc-muted">No machine data</span>
        )}
        {types.map(t => (
          <div class="flex flex-col gap-1">
            <div class="flex items-center justify-between">
              <span class="font-mc text-xs text-mc-white capitalize">{t.type.replace(/_/g, ' ')}</span>
              <span class="font-mc text-xs text-mc-muted">{t.mod.replace('modern_industrialization', 'MI').replace('mekanism', 'MEK')}</span>
            </div>
            <ProgressBar
              value={t.active_count}
              max={t.total_count}
              colour={t.active_percent > 50 ? 'emerald' : 'copper'}
              label={`${t.active_count}/${t.total_count} active`}
            />
          </div>
        ))}
      </div>
    </Panel>
  </div>
</Layout>

<script>
  const REFRESH_MS = 10_000;

  function setEl(id: string, val: string) {
    const el = document.getElementById(id);
    if (el) el.textContent = val;
  }

  function renderMekanism(machines: {
    name: string; type: string; active: boolean;
    energy_percent: number; progress: number; progress_total: number; progress_percent: number;
  }[]) {
    const list = document.getElementById('mek-list');
    if (!list) return;
    list.innerHTML = machines.length === 0
      ? '<p class="font-mc text-xs text-mc-muted px-4 py-6">No Mekanism machine data</p>'
      : machines.map(m => {
          const pctE = Math.min(100, Math.max(0, m.energy_percent));
          const pctP = Math.min(100, Math.max(0, m.progress_percent));
          const progressBar = m.active ? `
            <div class="flex flex-col gap-1 mt-2">
              <div class="flex justify-between">
                <span class="font-mc text-xs text-mc-muted">Progress: ${m.progress}/${m.progress_total}</span>
                <span class="font-mc text-xs text-mc-white">${pctP.toFixed(1)}%</span>
              </div>
              <div class="mc-progress-track">
                <div class="mc-progress-fill" style="width:${pctP}%;background-color:var(--color-mc-amethyst)">
                  <span class="absolute inset-0 top-0 bottom-1/2 bg-white/20"></span>
                </div>
              </div>
            </div>` : '';
          return `
            <div class="px-4 py-3 border-b border-mc-cobble/50 last:border-0">
              <div class="flex items-center justify-between mb-2">
                <div class="flex flex-col gap-0.5">
                  <span class="font-mc text-xs text-mc-white capitalize">${m.name}</span>
                  <span class="font-mc text-xs text-mc-muted">${m.type}</span>
                </div>
                <span class="font-mc text-xs px-2 py-0.5 ${m.active ? 'text-mc-emerald' : 'text-mc-muted'}">${m.active ? 'ACTIVE' : 'IDLE'}</span>
              </div>
              ${progressBar}
              <div class="flex flex-col gap-1 mt-1">
                <div class="flex justify-between">
                  <span class="font-mc text-xs text-mc-muted">Energy</span>
                  <span class="font-mc text-xs text-mc-white">${pctE.toFixed(1)}%</span>
                </div>
                <div class="mc-progress-track">
                  <div class="mc-progress-fill" style="width:${pctE}%;background-color:var(--color-mc-gold)">
                    <span class="absolute inset-0 top-0 bottom-1/2 bg-white/20"></span>
                  </div>
                </div>
              </div>
            </div>`;
        }).join('');
  }

  function renderMI(groups: { type: string; label: string; count: number }[]) {
    const list = document.getElementById('mi-list');
    if (!list) return;
    list.innerHTML = groups.length === 0
      ? '<p class="font-mc text-xs text-mc-muted px-4 py-6">No MI machine data</p>'
      : groups.map(g => `
          <div class="flex items-center justify-between px-4 py-2 border-b border-mc-cobble/50 last:border-0">
            <span class="font-mc text-xs text-mc-white capitalize">${g.label}</span>
            <span class="font-mc text-xs text-mc-diamond">${g.count}×</span>
          </div>`).join('');
  }

  async function refresh() {
    try {
      const data = await fetch('/api/machines').then(r => r.json());
      if (data.error) return;

      if (data.summary) {
        const s = data.summary;
        setEl('stat-active', String(s.active_machines));
        setEl('stat-total', String(s.total_machines));
        setEl('stat-active-pct', s.active_percent.toFixed(1) + '%');
      }
      if (data.mekanism) renderMekanism(data.mekanism);
      if (data.mi) renderMI(data.mi);

      const lu = document.getElementById('last-updated');
      if (lu) lu.textContent = `UPDATED ${new Date().toLocaleTimeString()}`;
    } catch (err) {
      console.error('machines refresh error', err);
    }
  }

  setInterval(refresh, REFRESH_MS);
</script>
