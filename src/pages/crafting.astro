---
import Layout from '@/layouts/Layout.astro';
import Panel from '@/components/mc/Panel.astro';
import StatCard from '@/components/mc/StatCard.astro';
import ProgressBar from '@/components/mc/ProgressBar.astro';
import LineChart from '@/components/charts/LineChart.astro';
import { craftingJobs, aeCPUs, craftingTaskCount, craftingTaskHistory } from '@/lib/queries';

const [jobsRes, cpusRes, taskCountRes, taskHistoryRes] = await Promise.allSettled([
  craftingJobs(),
  aeCPUs(),
  craftingTaskCount(),
  craftingTaskHistory('-1h'),
]);

const jobs = jobsRes.status === 'fulfilled' ? jobsRes.value : [];
const cpus = cpusRes.status === 'fulfilled' ? cpusRes.value : { total: 0, busy: 0, busy_percent: 0, cpus: [] };
const taskCount = taskCountRes.status === 'fulfilled' ? taskCountRes.value : 0;
const taskHistory = taskHistoryRes.status === 'fulfilled' ? taskHistoryRes.value : [];

// Merge job data into CPUs by cpu_index
const jobByCpuIndex = new Map(jobs.map(j => [j.cpu_index, j]));
const enrichedCpus = cpus.cpus.map((cpu, i) => ({
  ...cpu,
  job: jobByCpuIndex.get(i + 1) ?? null,
}));

function itemLabel(name: string): string {
  return name.replace(/^.*:/, '').replace(/_/g, ' ');
}

function fmtBytes(b: number): string {
  if (b >= 1_000_000) return (b / 1_000_000).toFixed(1) + 'M';
  if (b >= 1_000) return (b / 1_000).toFixed(0) + 'K';
  return String(b);
}

function fmtQty(n: number): string {
  if (n >= 1_000_000) return (n / 1_000_000).toFixed(1) + 'M';
  if (n >= 1_000) return (n / 1_000).toFixed(1) + 'k';
  return String(n);
}
---

<Layout title="MC Base — Crafting">
  <div class="mb-6 flex items-end justify-between">
    <div>
      <h1 class="font-mc text-mc-white text-xl">CRAFTING</h1>
      <p class="font-mc text-xs text-mc-muted mt-1">CPU STATUS</p>
    </div>
    <span id="last-updated" class="font-mc text-xs text-mc-muted"></span>
  </div>

  <!-- Stats row -->
  <div class="grid grid-cols-4 gap-3 mb-6">
    <StatCard label="CPUs Busy"  value={`${cpus.busy}/${cpus.total}`}  colour="amethyst" id="stat-cpus" />
    <StatCard label="Active Jobs" value={jobs.length}                   colour="amethyst" id="stat-jobs" />
    <StatCard label="CPUs Free"  value={cpus.total - cpus.busy}
      colour={cpus.total - cpus.busy > 0 ? 'emerald' : 'redstone'} id="stat-free" />
    <StatCard label="Task Queue" value={taskCount}                       colour="gold"     id="stat-tasks" />
  </div>

  <!-- Queue depth chart -->
  <Panel title="TASK QUEUE HISTORY" raised class="mb-6">
    <div class="flex items-center gap-2 mb-3">
      <span class="font-mc text-[9px] text-mc-muted">RANGE:</span>
      <button data-queue-range="-1h"  class="queue-range-btn mc-slot px-2 py-0.5 font-mc text-[9px] text-mc-gold">1H</button>
      <button data-queue-range="-6h"  class="queue-range-btn mc-slot px-2 py-0.5 font-mc text-[9px] text-mc-muted">6H</button>
      <button data-queue-range="-24h" class="queue-range-btn mc-slot px-2 py-0.5 font-mc text-[9px] text-mc-muted">24H</button>
    </div>
    <LineChart
      data={taskHistory}
      colour="var(--color-mc-gold)"
      height={80}
      id="chart-task-queue"
    />
    <p class="font-mc text-[9px] text-mc-muted mt-2">
      Sub-tasks queued across all active crafting jobs
    </p>
  </Panel>

  <!-- Full-width CPU grid -->
  <Panel title="CPU GRID" raised>
    <div id="cpu-grid" class="flex flex-wrap gap-3">
      {enrichedCpus.length === 0 && (
        <p class="font-mc text-xs text-mc-muted py-2">No CPU data</p>
      )}
      {enrichedCpus.map((cpu, i) => (
        <div
          class:list={[
            'group relative cursor-default pixel-border transition-all duration-300',
            'flex flex-col items-center justify-center gap-1',
            cpu.job ? 'w-32 h-28' : 'w-20 h-20',
            cpu.busy ? 'bg-mc-amethyst/20' : 'bg-mc-stone/40',
          ]}
          data-cpu={cpu.name}
          data-cpu-index={i + 1}
          data-busy={cpu.busy ? '1' : '0'}
        >
          {cpu.busy && (
            <div class="absolute inset-0 animate-pulse opacity-10 bg-mc-amethyst pointer-events-none" />
          )}
          <!-- CPU number -->
          <span class={`font-mc text-[10px] z-10 ${cpu.busy ? 'text-mc-amethyst' : 'text-mc-muted'}`}>
            {cpu.name.replace(/[^0-9]/g, '') || cpu.name.slice(-2)}
          </span>
          <!-- Status dot -->
          <span class:list={[
            'w-2 h-2 z-10',
            cpu.busy ? 'bg-mc-emerald shadow-[0_0_6px_var(--color-mc-emerald)]' : 'bg-mc-stone',
          ]} />
          <!-- Status / item label -->
          {cpu.job ? (
            <div class="flex flex-col items-center gap-0.5 z-10 px-1 w-full">
              <span class="font-mc text-[8px] text-mc-emerald">BUSY</span>
              <span class="font-mc text-[8px] text-mc-white capitalize text-center leading-tight line-clamp-2">
                {itemLabel(cpu.job.item)}
              </span>
              <span class="font-mc text-[9px] text-mc-amethyst">×{fmtQty(cpu.job.quantity)}</span>
            </div>
          ) : (
            <span class={`font-mc text-[8px] z-10 ${cpu.busy ? 'text-mc-emerald' : 'text-mc-muted'}`}>
              {cpu.busy ? 'BUSY' : 'FREE'}
            </span>
          )}
          <!-- Co-proc bar at bottom -->
          <div class="absolute bottom-0 left-0 right-0 h-1 bg-mc-shadow">
            <div
              class="h-full bg-mc-lapis transition-all duration-500"
              style={`width:${Math.min(100, cpu.coProcessors * 10)}%`}
            />
          </div>
          <!-- Tooltip -->
          <div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 z-50 hidden group-hover:flex flex-col gap-1 bg-mc-obsidian pixel-border p-2 min-w-44 pointer-events-none">
            <span class="font-mc text-[9px] text-mc-white">{cpu.name}</span>
            <span class={`font-mc text-[9px] ${cpu.busy ? 'text-mc-emerald' : 'text-mc-muted'}`}>
              {cpu.busy ? 'BUSY' : 'FREE'}
            </span>
            {cpu.job && (
              <>
                <div class="border-t border-mc-cobble/50 my-0.5" />
                <span class="font-mc text-[9px] text-mc-white capitalize">{itemLabel(cpu.job.item)}</span>
                <span class="font-mc text-[8px] text-mc-muted">{cpu.job.item}</span>
                <span class="font-mc text-[8px] text-mc-amethyst">qty: {cpu.job.quantity.toLocaleString()}</span>
              </>
            )}
            <div class="border-t border-mc-cobble/50 my-0.5" />
            <div class="flex items-center gap-2">
              <span class="font-mc text-[8px] text-mc-diamond w-14">STORAGE</span>
              <span class="font-mc text-[8px] text-mc-white">{fmtBytes(cpu.storage)}B</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="font-mc text-[8px] text-mc-lapis w-14">CO-PROCS</span>
              <span class="font-mc text-[8px] text-mc-white">{cpu.coProcessors}</span>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Utilisation bar -->
    <div class="mt-4">
      <ProgressBar
        value={cpus.busy}
        max={cpus.total || 1}
        colour="amethyst"
        label="CPU Utilisation"
        showPercent
        id="progress-cpu"
      />
    </div>
  </Panel>
</Layout>

<script>
  const REFRESH_MS = 5_000;

  type Job = { item: string; cpu: string; cpu_index: number; quantity: number };
  type CPU = { name: string; storage: number; coProcessors: number; busy: boolean };

  function itemLabel(name: string): string {
    return name.replace(/^.*:/, '').replace(/_/g, ' ');
  }

  function fmtBytes(b: number): string {
    if (b >= 1_000_000) return (b / 1_000_000).toFixed(1) + 'M';
    if (b >= 1_000) return (b / 1_000).toFixed(0) + 'K';
    return String(b);
  }

  function fmtQty(n: number): string {
    if (n >= 1_000_000) return (n / 1_000_000).toFixed(1) + 'M';
    if (n >= 1_000) return (n / 1_000).toFixed(1) + 'k';
    return String(n);
  }

  function setEl(id: string, val: string) {
    const el = document.getElementById(id);
    if (el) el.textContent = val;
  }

  function renderLineChart(containerId: string, points: {time: string; value: number}[], colour: string) {
    const container = document.getElementById(containerId);
    if (!container) return;
    if (points.length < 2) return;
    const W = container.clientWidth || 600;
    const H = 80;
    const pad = 4;
    const min = Math.min(...points.map(p => p.value));
    const max = Math.max(...points.map(p => p.value));
    const range = max - min || 1;
    const xs = points.map((_, i) => pad + (i / (points.length - 1)) * (W - pad * 2));
    const ys = points.map(p => H - pad - ((p.value - min) / range) * (H - pad * 2));
    const d = xs.map((x, i) => `${i === 0 ? 'M' : 'L'}${x.toFixed(1)},${ys[i]!.toFixed(1)}`).join(' ');
    const fillD = `${d} L${xs[xs.length-1]!.toFixed(1)},${H} L${xs[0]!.toFixed(1)},${H} Z`;
    const existing = container.querySelector('svg');
    const svgHtml = `<svg width="100%" height="${H}" viewBox="0 0 ${W} ${H}" preserveAspectRatio="none">
      <path d="${fillD}" fill="${colour}" opacity="0.15"/>
      <path d="${d}" fill="none" stroke="${colour}" stroke-width="1.5" opacity="0.9"/>
    </svg>`;
    if (existing) existing.outerHTML = svgHtml;
    else container.innerHTML = svgHtml;
  }

  function buildCpuCell(cpu: CPU, job: Job | null): string {
    const num = cpu.name.replace(/[^0-9]/g, '') || cpu.name.slice(-2);
    const coproPct = Math.min(100, cpu.coProcessors * 10);
    const hasJob = job !== null;
    const itemLine = hasJob
      ? `<div class="flex flex-col items-center gap-0.5 z-10 px-1 w-full">
           <span class="font-mc text-[8px] text-mc-emerald">BUSY</span>
           <span class="font-mc text-[8px] text-mc-white capitalize text-center leading-tight" style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden">${itemLabel(job!.item)}</span>
           <span class="font-mc text-[9px] text-mc-amethyst">×${fmtQty(job!.quantity)}</span>
         </div>`
      : `<span class="font-mc text-[8px] z-10 ${cpu.busy ? 'text-mc-emerald' : 'text-mc-muted'}">${cpu.busy ? 'BUSY' : 'FREE'}</span>`;

    const jobTooltip = hasJob
      ? `<div class="border-t border-mc-cobble/50 my-0.5"></div>
         <span class="font-mc text-[9px] text-mc-white capitalize">${itemLabel(job!.item)}</span>
         <span class="font-mc text-[8px] text-mc-muted">${job!.item}</span>
         <span class="font-mc text-[8px] text-mc-amethyst">qty: ${job!.quantity.toLocaleString()}</span>`
      : '';

    return `
      ${cpu.busy ? `<div class="absolute inset-0 animate-pulse opacity-10 bg-mc-amethyst pointer-events-none"></div>` : ''}
      <span class="font-mc text-[10px] z-10 ${cpu.busy ? 'text-mc-amethyst' : 'text-mc-muted'}">${num}</span>
      <span class="w-2 h-2 z-10 ${cpu.busy ? 'bg-mc-emerald shadow-[0_0_6px_var(--color-mc-emerald)]' : 'bg-mc-stone'}"></span>
      ${itemLine}
      <div class="absolute bottom-0 left-0 right-0 h-1 bg-mc-shadow">
        <div class="h-full bg-mc-lapis" style="width:${coproPct}%"></div>
      </div>
      <div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 z-50 hidden group-hover:flex flex-col gap-1 bg-mc-obsidian pixel-border p-2 min-w-44 pointer-events-none">
        <span class="font-mc text-[9px] text-mc-white">${cpu.name}</span>
        <span class="font-mc text-[9px] ${cpu.busy ? 'text-mc-emerald' : 'text-mc-muted'}">${cpu.busy ? 'BUSY' : 'FREE'}</span>
        ${jobTooltip}
        <div class="border-t border-mc-cobble/50 my-0.5"></div>
        <div class="flex items-center gap-2">
          <span class="font-mc text-[8px] text-mc-diamond w-14">STORAGE</span>
          <span class="font-mc text-[8px] text-mc-white">${fmtBytes(cpu.storage)}B</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="font-mc text-[8px] text-mc-lapis w-14">CO-PROCS</span>
          <span class="font-mc text-[8px] text-mc-white">${cpu.coProcessors}</span>
        </div>
      </div>`;
  }

  function renderCPUs(data: { total: number; busy: number; busy_percent: number; cpus: CPU[] }, jobs: Job[], taskCount?: number) {
    setEl('stat-cpus', `${data.busy}/${data.total}`);
    setEl('stat-jobs', String(jobs.filter(j => j).length));
    setEl('stat-free', String(data.total - data.busy));
    if (taskCount !== undefined) setEl('stat-tasks', String(taskCount));

    const fill = document.getElementById('progress-cpu') as HTMLElement | null;
    if (fill) fill.style.width = `${data.busy_percent.toFixed(1)}%`;
    const pctSpan = document.getElementById('progress-cpu-pct') as HTMLElement | null;
    if (pctSpan) pctSpan.textContent = `${data.busy_percent.toFixed(1)}%`;

    const grid = document.getElementById('cpu-grid');
    if (!grid) return;

    const jobByCpuIndex = new Map(jobs.map(j => [j.cpu_index, j]));

    for (let i = 0; i < data.cpus.length; i++) {
      const cpu = data.cpus[i]!;
      const job = jobByCpuIndex.get(i + 1) ?? null;
      const hasJob = job !== null;

      let cell = grid.querySelector(`[data-cpu-index="${i + 1}"]`) as HTMLElement | null;
      const wasBusy = cell?.dataset.busy === '1';

      if (!cell) {
        cell = document.createElement('div');
        grid.appendChild(cell);
      }

      cell.dataset.cpu = cpu.name;
      cell.dataset.cpuIndex = String(i + 1);
      cell.dataset.busy = cpu.busy ? '1' : '0';
      cell.innerHTML = buildCpuCell(cpu, job);
      cell.className = [
        'group relative cursor-default pixel-border transition-all duration-300',
        'flex flex-col items-center justify-center gap-1',
        hasJob ? 'w-32 h-28' : 'w-20 h-20',
        cpu.busy ? 'bg-mc-amethyst/20' : 'bg-mc-stone/40',
      ].join(' ');

      if (wasBusy !== cpu.busy) {
        cell.classList.add(cpu.busy ? 'scale-105' : 'opacity-60');
        setTimeout(() => cell!.classList.remove('scale-105', 'opacity-60'), 400);
      }
    }
  }

  async function refresh() {
    try {
      const data = await fetch('/api/crafting').then(r => r.json());
      if (data.error) return;
      if (data.cpus) renderCPUs(data.cpus, data.jobs ?? [], data.taskCount);
      
      // Update task queue chart
      if (data.taskHistory) {
        renderLineChart('chart-task-queue', data.taskHistory, 'var(--color-mc-gold)');
      }
      
      const el = document.getElementById('last-updated');
      if (el) el.textContent = `UPDATED ${new Date().toLocaleTimeString()}`;
    } catch (err) {
      console.error('crafting refresh error', err);
    }
  }

  // Queue chart range selector
  document.querySelectorAll('.queue-range-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const range = btn.getAttribute('data-queue-range') ?? '-1h';
      document.querySelectorAll('.queue-range-btn').forEach(b => {
        b.className = 'queue-range-btn mc-slot px-2 py-0.5 font-mc text-[9px] ' +
          (b === btn ? 'text-mc-gold' : 'text-mc-muted');
      });
      const data = await fetch(`/api/crafting?range=${range}`).then(r => r.json()).catch(() => null);
      if (data?.taskHistory) {
        renderLineChart('chart-task-queue', data.taskHistory, 'var(--color-mc-gold)');
      }
    });
  });

  setInterval(refresh, REFRESH_MS);
  refresh();
</script>
