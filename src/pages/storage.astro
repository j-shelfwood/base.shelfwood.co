---
import Layout from '@/layouts/Layout.astro';
import Panel from '@/components/mc/Panel.astro';
import StatCard from '@/components/mc/StatCard.astro';
import ProgressBar from '@/components/mc/ProgressBar.astro';
import { aeSummary, aeItems, aeItemVelocity } from '@/lib/queries';

const [summaryRes, itemsRes, velocityRes] = await Promise.allSettled([
  aeSummary(),
  aeItems(),
  aeItemVelocity('-30m', 15),
]);

const summary  = summaryRes.status  === 'fulfilled' ? summaryRes.value  : null;
const items    = itemsRes.status    === 'fulfilled' ? itemsRes.value    : [];
const velocity = velocityRes.status === 'fulfilled' ? velocityRes.value : [];

function fmt(n: number): string {
  if (n >= 1_000_000) return (n / 1_000_000).toFixed(2) + 'M';
  if (n >= 1_000) return (n / 1_000).toFixed(1) + 'K';
  return n.toLocaleString();
}

function itemLabel(registryName: string): string {
  return registryName
    .replace(/^.*:/, '')
    .replace(/_/g, ' ');
}
---

<Layout title="MC Base — Storage">
  <div class="mb-6 flex items-end justify-between gap-4 flex-wrap">
    <div>
      <h1 class="font-mc text-mc-white text-xl">STORAGE</h1>
      <p class="font-mc text-xs text-mc-muted mt-1">AE2 ITEM BROWSER</p>
    </div>
    <div class="flex items-center gap-3">
      <!-- Sort controls -->
      <div class="flex items-center gap-1">
        <button id="sort-count" class="mc-slot px-3 py-1.5 font-mc text-xs text-mc-diamond">COUNT ▼</button>
        <button id="sort-name" class="mc-slot px-3 py-1.5 font-mc text-xs text-mc-muted">NAME</button>
      </div>
      <!-- Search box -->
      <div class="mc-slot px-3 py-2 flex items-center gap-2">
        <span class="font-mc text-xs text-mc-muted">SEARCH:</span>
        <input
          id="item-search"
          type="text"
          placeholder="iron ingot..."
          class="bg-transparent font-mc text-xs text-mc-white outline-none placeholder:text-mc-stone w-40"
          autocomplete="off"
        />
      </div>
    </div>
  </div>

  <!-- Storage stats -->
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-6">
    <StatCard label="Total Items" value={summary ? fmt(summary.items_total) : '—'} colour="diamond" id="stat-total-items" />
    <StatCard label="Unique Types" value={summary?.items_unique ?? '—'} colour="diamond" id="stat-unique" />
    <StatCard label="Item Storage" value={summary ? ((summary.item_storage_used / (summary.item_storage_total || 1)) * 100).toFixed(1) + '%' : '—'} colour="lapis" id="stat-storage-pct" />
    <StatCard label="Fluids" value={summary ? fmt(summary.fluids_total) + ' mB' : '—'} colour="diamond" id="stat-fluids" />
  </div>

  <!-- Storage capacity bars -->
  {summary && (
    <div class="mb-6 flex flex-col gap-3">
      <ProgressBar
        value={summary.item_storage_used}
        max={summary.item_storage_total || 1}
        colour="diamond"
        label="Item Cell Capacity"
        showPercent
        id="progress-storage"
      />
      {summary.fluid_storage_total > 0 && (
        <ProgressBar
          value={summary.fluid_storage_used}
          max={summary.fluid_storage_total}
          colour="lapis"
          label="Fluid Cell Capacity"
          showPercent
          id="progress-fluid-storage"
        />
      )}
      {summary.chemical_storage_total > 0 && (
        <ProgressBar
          value={summary.chemical_storage_used}
          max={summary.chemical_storage_total}
          colour="amethyst"
          label="Chemical Cell Capacity"
          showPercent
          id="progress-chem-storage"
        />
      )}
    </div>
  )}

  <!-- Top movers -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-6">
    <div data-panel="producers">
      <Panel title="TOP PRODUCERS · 30m" raised noPadding>
        <div class="divide-y divide-mc-cobble/50">
          {(() => {
            const producers = velocity.filter(v => v.delta > 0);
            const max = producers[0]?.delta ?? 1;
            return producers.length > 0
              ? producers.slice(0, 8).map(v => {
                  const pct = Math.min(100, (v.delta / max) * 100);
                  return (
                    <div class="px-4 py-2 flex flex-col gap-1">
                      <div class="flex items-center justify-between">
                        <span class="font-mc text-xs text-mc-white capitalize">{itemLabel(v.item)}</span>
                        <span class="font-mc text-xs text-mc-emerald">+{fmt(v.delta)}</span>
                      </div>
                      <div class="mc-progress-track">
                        <div class="mc-progress-fill" style={`width:${pct}%;background-color:var(--color-mc-emerald);opacity:0.6`} />
                      </div>
                    </div>
                  );
                })
              : <p class="font-mc text-xs text-mc-muted px-4 py-4">No production detected</p>;
          })()}
        </div>
      </Panel>
    </div>

    <div data-panel="consumers">
      <Panel title="TOP CONSUMERS · 30m" raised noPadding>
        <div class="divide-y divide-mc-cobble/50">
          {(() => {
            const consumers = velocity.filter(v => v.delta < 0);
            const max = Math.abs(consumers[0]?.delta ?? 1);
            return consumers.length > 0
              ? consumers.slice(0, 8).map(v => {
                  const pct = Math.min(100, (Math.abs(v.delta) / max) * 100);
                  return (
                    <div class="px-4 py-2 flex flex-col gap-1">
                      <div class="flex items-center justify-between">
                        <span class="font-mc text-xs text-mc-white capitalize">{itemLabel(v.item)}</span>
                        <span class="font-mc text-xs text-mc-redstone">{fmt(v.delta)}</span>
                      </div>
                      <div class="mc-progress-track">
                        <div class="mc-progress-fill" style={`width:${pct}%;background-color:var(--color-mc-redstone);opacity:0.6`} />
                      </div>
                    </div>
                  );
                })
              : <p class="font-mc text-xs text-mc-muted px-4 py-4">No consumption detected</p>;
          })()}
        </div>
      </Panel>
    </div>
  </div>

  <!-- Item list -->
  <Panel title="ITEMS" raised noPadding>
    <div id="item-list" class="divide-y divide-mc-cobble/50">
      {items.map(item => (
        <div
          class="flex items-center justify-between px-4 py-2 hover:bg-mc-stone/20 transition-colors cursor-pointer item-row"
          data-item={item.item}
        >
          <div class="flex flex-col gap-0.5">
            <span class="font-mc text-xs text-mc-white capitalize">{itemLabel(item.item)}</span>
            <span class="font-mc text-xs text-mc-muted">{item.item}</span>
          </div>
          <span class="font-mc text-sm text-mc-diamond shrink-0">{fmt(item.count)}</span>
        </div>
      ))}
      {items.length === 0 && (
        <p class="font-mc text-xs text-mc-muted px-4 py-6">No items found</p>
      )}
    </div>
  </Panel>
</Layout>

<script>
  const REFRESH_MS = 60_000;
  let currentQuery = '';
  let sortMode: 'count' | 'name' = 'count';
  let sortDir: 'desc' | 'asc' = 'desc';
  let allItems: { item: string; count: number }[] = [];

  function itemLabel(name: string): string {
    return name.replace(/^.*:/, '').replace(/_/g, ' ');
  }

  function fmt(n: number): string {
    if (n >= 1_000_000) return (n / 1_000_000).toFixed(2) + 'M';
    if (n >= 1_000) return (n / 1_000).toFixed(1) + 'K';
    return n.toLocaleString();
  }

  function sortItems(items: { item: string; count: number }[]) {
    const copy = [...items];
    if (sortMode === 'name') {
      copy.sort((a, b) => {
        const cmp = itemLabel(a.item).localeCompare(itemLabel(b.item));
        return sortDir === 'asc' ? cmp : -cmp;
      });
    } else {
      copy.sort((a, b) => sortDir === 'desc' ? b.count - a.count : a.count - b.count);
    }
    return copy;
  }

  function updateSortButtons() {
    const btnCount = document.getElementById('sort-count');
    const btnName = document.getElementById('sort-name');
    if (btnCount) {
      const arrow = sortMode === 'count' ? (sortDir === 'desc' ? ' ▼' : ' ▲') : '';
      btnCount.textContent = 'COUNT' + arrow;
      btnCount.className = `mc-slot px-3 py-1.5 font-mc text-xs ${sortMode === 'count' ? 'text-mc-diamond' : 'text-mc-muted'}`;
    }
    if (btnName) {
      const arrow = sortMode === 'name' ? (sortDir === 'asc' ? ' ▲' : ' ▼') : '';
      btnName.textContent = 'NAME' + arrow;
      btnName.className = `mc-slot px-3 py-1.5 font-mc text-xs ${sortMode === 'name' ? 'text-mc-diamond' : 'text-mc-muted'}`;
    }
  }

  function renderItems(items: { item: string; count: number }[]) {
    const list = document.getElementById('item-list');
    if (!list) return;
    const sorted = sortItems(items);
    list.innerHTML = sorted.length === 0
      ? '<p class="font-mc text-xs text-mc-muted px-4 py-6">No items found</p>'
      : sorted.map(i => `
        <div class="flex items-center justify-between px-4 py-2 hover:bg-mc-stone/20 transition-colors cursor-pointer item-row" data-item="${i.item}">
          <div class="flex flex-col gap-0.5">
            <span class="font-mc text-xs text-mc-white capitalize">${itemLabel(i.item)}</span>
            <span class="font-mc text-xs text-mc-muted">${i.item}</span>
          </div>
          <span class="font-mc text-sm text-mc-diamond">${fmt(i.count)}</span>
        </div>
      `).join('');
  }

  async function loadItems(q?: string) {
    const url = q ? `/api/ae-items?q=${encodeURIComponent(q)}` : '/api/ae-items';
    const data = await fetch(url).then(r => r.json());
    if (data.items) {
      allItems = data.items;
      renderItems(allItems);
    }
  }

  // Sort button handlers
  document.getElementById('sort-count')?.addEventListener('click', () => {
    if (sortMode === 'count') {
      sortDir = sortDir === 'desc' ? 'asc' : 'desc';
    } else {
      sortMode = 'count';
      sortDir = 'desc';
    }
    updateSortButtons();
    renderItems(allItems);
  });
  document.getElementById('sort-name')?.addEventListener('click', () => {
    if (sortMode === 'name') {
      sortDir = sortDir === 'asc' ? 'desc' : 'asc';
    } else {
      sortMode = 'name';
      sortDir = 'asc';
    }
    updateSortButtons();
    renderItems(allItems);
  });

  // Search debounce
  let searchTimeout: ReturnType<typeof setTimeout>;
  const searchInput = document.getElementById('item-search') as HTMLInputElement | null;
  searchInput?.addEventListener('input', () => {
    clearTimeout(searchTimeout);
    searchTimeout = setTimeout(() => {
      currentQuery = searchInput.value.trim();
      loadItems(currentQuery || undefined);
    }, 300);
  });

  // Velocity refresh (every 2 min — 30m window, no need to hammer it)
  async function loadVelocity() {
    const data = await fetch('/api/ae-items?velocity=1').then(r => r.json()).catch(() => null);
    if (!data?.velocity) return;

    function renderVelocity(
      selector: string,
      items: { item: string; delta: number }[],
      sign: 1 | -1,
      colour: string,
      emptyMsg: string
    ) {
      const panel = document.querySelector(selector) as HTMLElement | null;
      if (!panel) return;
      const container = panel.querySelector('.divide-y') as HTMLElement | null;
      if (!container) return;
      const filtered = items.filter(v => Math.sign(v.delta) === sign);
      if (filtered.length === 0) {
        container.innerHTML = `<p class="font-mc text-xs text-mc-muted px-4 py-4">${emptyMsg}</p>`;
        return;
      }
      const max = Math.abs(filtered[0]?.delta ?? 1);
      container.innerHTML = filtered.slice(0, 8).map(v => {
        const pct = Math.min(100, (Math.abs(v.delta) / max) * 100);
        const label = v.item.replace(/^.*:/, '').replace(/_/g, ' ');
        const fmtDelta = sign === 1 ? `+${fmt(v.delta)}` : fmt(v.delta);
        return `<div class="px-4 py-2 flex flex-col gap-1">
          <div class="flex items-center justify-between">
            <span class="font-mc text-xs text-mc-white capitalize">${label}</span>
            <span class="font-mc text-xs ${colour}">${fmtDelta}</span>
          </div>
          <div class="mc-progress-track">
            <div class="mc-progress-fill" style="width:${pct}%;background-color:${colour === 'text-mc-emerald' ? 'var(--color-mc-emerald)' : 'var(--color-mc-redstone)'};opacity:0.6"></div>
          </div>
        </div>`;
      }).join('');
    }

    renderVelocity('[data-panel="producers"]', data.velocity, 1,  'text-mc-emerald', 'No production detected');
    renderVelocity('[data-panel="consumers"]', data.velocity, -1, 'text-mc-redstone', 'No consumption detected');
  }

  setInterval(loadVelocity, 120_000);

  // Auto-refresh items
  setInterval(() => loadItems(currentQuery || undefined), REFRESH_MS);
</script>
