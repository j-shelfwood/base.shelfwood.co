        <div class="flex items-center justify-between px-4 py-2 hover:bg-mc-stone/20 transition-colors cursor-pointer fluid-row" data-fluid="${f.fluid}">
          <div class="flex flex-col gap-0.5">
            <span class="font-mc text-xs text-mc-white capitalize">${itemLabel(f.fluid)}</span>
            <span class="font-mc text-xs text-mc-muted">${f.fluid}</span>
          </div>
          <span class="font-mc text-sm text-mc-lapis">${fmtMb(f.amount)}</span>
        </div>
      `).join('');
    
    list.querySelectorAll('.fluid-row').forEach(row => {
      row.addEventListener('click', () => {
        const fluid = row.getAttribute('data-fluid');
        if (fluid) showHistory('fluid', fluid, row as HTMLElement, 'lapis');
      });
    });
