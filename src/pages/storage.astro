  function renderChemicals(chemicals: { chemical: string; amount: number }[]) {
    const list = document.getElementById('chemical-list');
    if (!list) return;
    const sorted = sortChemicals(chemicals);
    list.innerHTML = sorted.length === 0
      ? '<p class="font-mc text-xs text-mc-muted px-4 py-6">No chemicals found</p>'
      : sorted.map(c => `
        <div class="flex items-center justify-between px-4 py-2 hover:bg-mc-stone/20 transition-colors cursor-pointer chemical-row" data-chemical="${c.chemical}">
          <div class="flex flex-col gap-0.5">
            <span class="font-mc text-xs text-mc-white capitalize">${itemLabel(c.chemical)}</span>
            <span class="font-mc text-xs text-mc-muted">${c.chemical}</span>
          </div>
          <span class="font-mc text-sm text-mc-amethyst">${fmtMb(c.amount)}</span>
        </div>
      `).join('');
    
    list.querySelectorAll('.chemical-row').forEach(row => {
      row.addEventListener('click', () => {
        const chemical = row.getAttribute('data-chemical');
        if (chemical) showHistory('chemical', chemical, row as HTMLElement, 'amethyst');
      });
    });
  }

  async function loadItems(q?: string) {
    const url = q ? `/api/ae-items?q=${encodeURIComponent(q)}` : '/api/ae-items';
    const data = await fetch(url).then(r => r.json());
    if (data.items) {
      allItems = data.items;
      renderItems(allItems);
    }
  }

  async function loadFluids() {
    const data = await fetch('/api/fluids').then(r => r.json()).catch(() => ({ fluids: [] }));
    if (data.fluids) {
      allFluids = data.fluids;
      renderFluids(allFluids);
    }
  }

  async function loadChemicals() {
    const data = await fetch('/api/chemicals').then(r => r.json()).catch(() => ({ chemicals: [] }));
    if (data.chemicals) {
      allChemicals = data.chemicals;
      renderChemicals(allChemicals);
    }
  }

  // Sort button handlers
  document.getElementById('sort-count')?.addEventListener('click', () => {
    if (sortMode === 'count') {
      sortDir = sortDir === 'desc' ? 'asc' : 'desc';
    } else {
      sortMode = 'count';
      sortDir = 'desc';
    }
    updateSortButtons();
    if (currentTab === 'items') renderItems(allItems);
    else if (currentTab === 'fluids') renderFluids(allFluids);
    else if (currentTab === 'chemicals') renderChemicals(allChemicals);
  });
  document.getElementById('sort-name')?.addEventListener('click', () => {
    if (sortMode === 'name') {
      sortDir = sortDir === 'asc' ? 'desc' : 'asc';
    } else {
      sortMode = 'name';
      sortDir = 'asc';
    }
    updateSortButtons();
    if (currentTab === 'items') renderItems(allItems);
    else if (currentTab === 'fluids') renderFluids(allFluids);
    else if (currentTab === 'chemicals') renderChemicals(allChemicals);
  });

  // Search debounce
  let searchTimeout: ReturnType<typeof setTimeout>;
  const searchInput = document.getElementById('item-search') as HTMLInputElement | null;
  searchInput?.addEventListener('input', () => {
    clearTimeout(searchTimeout);
    searchTimeout = setTimeout(() => {
      currentQuery = searchInput.value.trim();
      loadItems(currentQuery || undefined);
    }, 300);
  });

  // Velocity refresh (every 2 min — 30m window, no need to hammer it)
  async function loadVelocity() {
    const data = await fetch('/api/ae-items?velocity=1').then(r => r.json()).catch(() => null);
    if (!data?.velocity) return;

    function renderVelocity(
      selector: string,
      items: { item: string; delta: number }[],
      sign: 1 | -1,
      colour: string,
      emptyMsg: string,
      formatter: (n: number) => string
    ) {
      const panel = document.querySelector(selector) as HTMLElement | null;
      if (!panel) return;
      const container = panel.querySelector('.divide-y') as HTMLElement | null;
      if (!container) return;
      const filtered = items.filter(v => Math.sign(v.delta) === sign);
      if (filtered.length === 0) {
        container.innerHTML = `<p class="font-mc text-xs text-mc-muted px-4 py-4">${emptyMsg}</p>`;
        return;
      }
      const max = Math.abs(filtered[0]?.delta ?? 1);
      container.innerHTML = filtered.slice(0, 8).map(v => {
        const pct = Math.min(100, (Math.abs(v.delta) / max) * 100);
        const label = v.item.replace(/^.*:/, '').replace(/_/g, ' ');
        const fmtDelta = sign === 1 ? `+${formatter(v.delta)}` : formatter(v.delta);
        return `<div class="px-4 py-2 flex flex-col gap-1">
          <div class="flex items-center justify-between">
            <span class="font-mc text-xs text-mc-white capitalize">${label}</span>
            <span class="font-mc text-xs ${colour}">${fmtDelta}</span>
          </div>
          <div class="mc-progress-track">
            <div class="mc-progress-fill" style="width:${pct}%;background-color:${colour === 'text-mc-emerald' ? 'var(--color-mc-emerald)' : 'var(--color-mc-redstone)'};opacity:0.6"></div>
          </div>
        </div>`;
      }).join('');
    }

    renderVelocity('[data-panel="producers"]', data.velocity, 1,  'text-mc-emerald', 'No production detected', fmt);
    renderVelocity('[data-panel="consumers"]', data.velocity, -1, 'text-mc-redstone', 'No consumption detected', fmt);
  }

  async function loadFluidVelocity() {
    const data = await fetch('/api/fluids?velocity=1').then(r => r.json()).catch(() => null);
    if (!data?.velocity) return;

    function renderVelocity(
      selector: string,
      items: { item: string; delta: number }[],
      sign: 1 | -1,
      colour: string,
      emptyMsg: string
    ) {
      const panel = document.querySelector(selector) as HTMLElement | null;
      if (!panel) return;
      const container = panel.querySelector('.divide-y') as HTMLElement | null;
      if (!container) return;
      const filtered = items.filter(v => Math.sign(v.delta) === sign);
      if (filtered.length === 0) {
        container.innerHTML = `<p class="font-mc text-xs text-mc-muted px-4 py-4">${emptyMsg}</p>`;
        return;
      }
      const max = Math.abs(filtered[0]?.delta ?? 1);
      container.innerHTML = filtered.slice(0, 8).map(v => {
        const pct = Math.min(100, (Math.abs(v.delta) / max) * 100);
        const label = v.item.replace(/^.*:/, '').replace(/_/g, ' ');
        const fmtDelta = sign === 1 ? `+${fmtMb(v.delta)}` : fmtMb(v.delta);
        return `<div class="px-4 py-2 flex flex-col gap-1">
          <div class="flex items-center justify-between">
            <span class="font-mc text-xs text-mc-white capitalize">${label}</span>
            <span class="font-mc text-xs ${colour}">${fmtDelta}</span>
          </div>
          <div class="mc-progress-track">
            <div class="mc-progress-fill" style="width:${pct}%;background-color:${colour === 'text-mc-emerald' ? 'var(--color-mc-emerald)' : 'var(--color-mc-redstone)'};opacity:0.6"></div>
          </div>
        </div>`;
      }).join('');
    }

    renderVelocity('[data-panel="fluid-producers"]', data.velocity, 1,  'text-mc-emerald', 'No production detected');
    renderVelocity('[data-panel="fluid-consumers"]', data.velocity, -1, 'text-mc-redstone', 'No consumption detected');
  }

  async function loadChemicalVelocity() {
    const data = await fetch('/api/chemicals?velocity=1').then(r => r.json()).catch(() => null);
    if (!data?.velocity) return;

    function renderVelocity(
      selector: string,
      items: { item: string; delta: number }[],
      sign: 1 | -1,
      colour: string,
      emptyMsg: string
    ) {
      const panel = document.querySelector(selector) as HTMLElement | null;
      if (!panel) return;
      const container = panel.querySelector('.divide-y') as HTMLElement | null;
      if (!container) return;
      const filtered = items.filter(v => Math.sign(v.delta) === sign);
      if (filtered.length === 0) {
        container.innerHTML = `<p class="font-mc text-xs text-mc-muted px-4 py-4">${emptyMsg}</p>`;
        return;
      }
      const max = Math.abs(filtered[0]?.delta ?? 1);
      container.innerHTML = filtered.slice(0, 8).map(v => {
        const pct = Math.min(100, (Math.abs(v.delta) / max) * 100);
        const label = v.item.replace(/^.*:/, '').replace(/_/g, ' ');
        const fmtDelta = sign === 1 ? `+${fmtMb(v.delta)}` : fmtMb(v.delta);
        return `<div class="px-4 py-2 flex flex-col gap-1">
          <div class="flex items-center justify-between">
            <span class="font-mc text-xs text-mc-white capitalize">${label}</span>
            <span class="font-mc text-xs ${colour}">${fmtDelta}</span>
          </div>
          <div class="mc-progress-track">
            <div class="mc-progress-fill" style="width:${pct}%;background-color:${colour === 'text-mc-emerald' ? 'var(--color-mc-emerald)' : 'var(--color-mc-redstone)'};opacity:0.6"></div>
          </div>
        </div>`;
      }).join('');
    }

    renderVelocity('[data-panel="chemical-producers"]', data.velocity, 1,  'text-mc-emerald', 'No production detected');
    renderVelocity('[data-panel="chemical-consumers"]', data.velocity, -1, 'text-mc-redstone', 'No consumption detected');
  }

  setInterval(loadVelocity, 120_000);
  setInterval(loadFluidVelocity, 120_000);
  setInterval(loadChemicalVelocity, 120_000);

  // Auto-refresh
  setInterval(() => {
    if (currentTab === 'items') loadItems(currentQuery || undefined);
    else if (currentTab === 'fluids') loadFluids();
    else if (currentTab === 'chemicals') loadChemicals();
  }, REFRESH_MS);

  // Attach click handlers to SSR-rendered rows (before first client fetch completes)
  document.querySelectorAll('.item-row').forEach(row => {
    row.addEventListener('click', () => {
      const item = row.getAttribute('data-item');
      if (item) showHistory('item', item, row as HTMLElement, 'diamond');
    });
  });
  document.querySelectorAll('.fluid-row').forEach(row => {
    row.addEventListener('click', () => {
      const fluid = row.getAttribute('data-fluid');
      if (fluid) showHistory('fluid', fluid, row as HTMLElement, 'lapis');
    });
  });
  document.querySelectorAll('.chemical-row').forEach(row => {
    row.addEventListener('click', () => {
      const chemical = row.getAttribute('data-chemical');
      if (chemical) showHistory('chemical', chemical, row as HTMLElement, 'amethyst');
    });
  });

  // Storage history range selector
  document.querySelectorAll<HTMLButtonElement>('.storage-hist-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const range = btn.dataset.storageRange;
      if (!range) return;
      document.querySelectorAll<HTMLButtonElement>('.storage-hist-btn').forEach(b => {
        const active = b.dataset.storageRange === range;
        b.className = `storage-hist-btn font-mc text-sm px-3 py-1 pixel-border transition-colors ${active ? 'bg-mc-diamond/20 text-mc-diamond border-mc-diamond' : 'bg-mc-stone/40 text-mc-muted hover:text-mc-white'}`;
      });
      const loading = document.getElementById('storage-hist-loading');
      if (loading) loading.classList.remove('hidden');
      const data = await fetch(`/api/ae-summary?range=${range}`).then(r => r.json()).catch(() => null);
      if (loading) loading.classList.add('hidden');
      if (!data) return;
      if (data.itemsHistory) renderSvgLine('chart-storage-items', data.itemsHistory, 'var(--color-mc-diamond)', '');
      if (data.energyHistory) renderSvgLine('chart-storage-energy', data.energyHistory, 'var(--color-mc-amethyst)', ' FE/t');
      if (data.storageHistory) renderSvgLine('chart-storage-fill', data.storageHistory, 'var(--color-mc-lapis)', ' slots');
    });
  });

  // Initial load
  loadItems();
  loadVelocity();
  loadFluids();
  loadChemicals();
  loadFluidVelocity();
  loadChemicalVelocity();
</script>
