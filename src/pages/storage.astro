---
import Layout from '@/layouts/Layout.astro';
import Panel from '@/components/mc/Panel.astro';
import StatCard from '@/components/mc/StatCard.astro';
import ProgressBar from '@/components/mc/ProgressBar.astro';
import LineChart from '@/components/charts/LineChart.astro';
import { aeSummary, aeItems, aeItemVelocity, aeFluids, aeFluidVelocity, aeChemicals, aeChemicalVelocity, aeSummaryHistory } from '@/lib/queries';

const [summaryRes, itemsRes, velocityRes, fluidRes, fluidVelRes, chemRes, chemVelRes, itemsHistRes, energyHistRes, storageHistRes] = await Promise.allSettled([
  aeSummary(),
  aeItems(),
  aeItemVelocity('-30m', 15),
  aeFluids(),
  aeFluidVelocity('-30m', 15),
  aeChemicals(),
  aeChemicalVelocity('-30m', 15),
  aeSummaryHistory('items_total', '-1h'),
  aeSummaryHistory('energy_usage', '-1h'),
  aeSummaryHistory('item_storage_used', '-1h'),
]);

const summary  = summaryRes.status  === 'fulfilled' ? summaryRes.value  : null;
const items    = itemsRes.status    === 'fulfilled' ? itemsRes.value    : [];
const velocity = velocityRes.status === 'fulfilled' ? velocityRes.value : [];
const fluids = fluidRes.status === 'fulfilled' ? fluidRes.value : [];
const fluidVelocity = fluidVelRes.status === 'fulfilled' ? fluidVelRes.value : [];
const chemicals = chemRes.status === 'fulfilled' ? chemRes.value : [];
const chemVelocity = chemVelRes.status === 'fulfilled' ? chemVelRes.value : [];
const aeItemsHist   = itemsHistRes.status   === 'fulfilled' ? itemsHistRes.value   : [];
const aeEnergyHist  = energyHistRes.status  === 'fulfilled' ? energyHistRes.value  : [];
const aeStorageHist = storageHistRes.status === 'fulfilled' ? storageHistRes.value : [];

function fmt(n: number): string {
  if (n >= 1_000_000) return (n / 1_000_000).toFixed(2) + 'M';
  if (n >= 1_000) return (n / 1_000).toFixed(1) + 'K';
  return n.toLocaleString();
}

function itemLabel(registryName: string): string {
  return registryName
    .replace(/^.*:/, '')
    .replace(/_/g, ' ');
}

function fmtMb(n: number): string {
  if (n >= 1_000_000) return (n / 1_000_000).toFixed(2) + 'M mB';
  if (n >= 1_000) return (n / 1_000).toFixed(1) + 'K mB';
  return n.toLocaleString() + ' mB';
}

const totalFluids = fluids.reduce((sum, f) => sum + f.amount, 0);
const totalChemicals = chemicals.reduce((sum, c) => sum + c.amount, 0);
---

<Layout title="MC Base — Storage">
  <div class="mb-6 flex items-end justify-between gap-4 flex-wrap">
    <div>
      <h1 class="font-mc text-mc-white text-xl">STORAGE</h1>
      <p class="font-mc text-xs text-mc-muted mt-1">AE2 BROWSER</p>
    </div>
    <div class="flex items-center gap-3">
      <!-- Sort controls -->
      <div class="flex items-center gap-1">
        <button id="sort-count" class="mc-slot px-3 py-1.5 font-mc text-xs text-mc-diamond">COUNT ▼</button>
        <button id="sort-name" class="mc-slot px-3 py-1.5 font-mc text-xs text-mc-muted">NAME</button>
      </div>
      <!-- Search box -->
      <div class="mc-slot px-3 py-2 flex items-center gap-2">
        <span class="font-mc text-xs text-mc-muted">SEARCH:</span>
        <input
          id="item-search"
          type="text"
          placeholder="iron ingot..."
          class="bg-transparent font-mc text-xs text-mc-white outline-none placeholder:text-mc-stone w-40"
          autocomplete="off"
        />
      </div>
    </div>
  </div>

  <!-- AE Overview Charts -->
  <div class="flex items-center gap-2 mb-3">
    <span class="font-mc text-base text-mc-muted">RANGE:</span>
    {[['1H','-1h'],['6H','-6h'],['24H','-24h'],['7D','-7d'],['14D','-14d'],['21D','-21d'],['31D','-31d']].map(([label, val]) => (
      <button data-storage-range={val}
        class:list={['storage-hist-btn font-mc text-sm px-3 py-1 pixel-border transition-colors',
          val === '-1h' ? 'bg-mc-diamond/20 text-mc-diamond border-mc-diamond' : 'bg-mc-stone/40 text-mc-muted hover:text-mc-white']}
      >{label}</button>
    ))}
    <span id="storage-hist-loading" class="font-mc text-sm text-mc-muted hidden">LOADING...</span>
  </div>
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-3 mb-6">
    <Panel title="TOTAL ITEMS STORED" raised>
      <LineChart data={aeItemsHist} colour="var(--color-mc-diamond)" height={80} suffix="" id="chart-storage-items" />
    </Panel>
    <Panel title="AE ENERGY USAGE" raised>
      <LineChart data={aeEnergyHist} colour="var(--color-mc-amethyst)" height={80} suffix=" FE/t" id="chart-storage-energy" />
    </Panel>
    <Panel title="STORAGE FILL" raised>
      <LineChart data={aeStorageHist} colour="var(--color-mc-lapis)" height={80} suffix=" slots" id="chart-storage-fill" />
    </Panel>
  </div>

  <!-- Tabs -->
  <div class="flex gap-1 mb-6" id="storage-tabs">
    <button data-tab="items" class="tab-btn mc-slot px-4 py-2 font-mc text-xs text-mc-diamond">ITEMS</button>
    <button data-tab="fluids" class="tab-btn mc-slot px-4 py-2 font-mc text-xs text-mc-muted">FLUIDS</button>
    <button data-tab="chemicals" class="tab-btn mc-slot px-4 py-2 font-mc text-xs text-mc-muted">CHEMICALS</button>
  </div>

  <!-- Tab: Items -->
  <div id="tab-items">

  <!-- Storage stats -->
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-6">
    <StatCard label="Total Items" value={summary ? fmt(summary.items_total) : '—'} colour="diamond" id="stat-total-items" />
    <StatCard label="Unique Types" value={summary?.items_unique ?? '—'} colour="diamond" id="stat-unique" />
    <StatCard label="Item Storage" value={summary ? ((summary.item_storage_used / (summary.item_storage_total || 1)) * 100).toFixed(1) + '%' : '—'} colour="lapis" id="stat-storage-pct" />
    <StatCard label="Fluids" value={summary ? fmt(summary.fluids_total) + ' mB' : '—'} colour="diamond" id="stat-fluids" />
  </div>

  <!-- Storage capacity bars -->
  {summary && (
    <div class="mb-6 flex flex-col gap-3">
      <ProgressBar
        value={summary.item_storage_used}
        max={summary.item_storage_total || 1}
        colour="diamond"
        label="Item Cell Capacity"
        showPercent
        id="progress-storage"
      />
      {summary.fluid_storage_total > 0 && (
        <ProgressBar
          value={summary.fluid_storage_used}
          max={summary.fluid_storage_total}
          colour="lapis"
          label="Fluid Cell Capacity"
          showPercent
          id="progress-fluid-storage"
        />
      )}
      {summary.chemical_storage_total > 0 && (
        <ProgressBar
          value={summary.chemical_storage_used}
          max={summary.chemical_storage_total}
          colour="amethyst"
          label="Chemical Cell Capacity"
          showPercent
          id="progress-chem-storage"
        />
      )}
    </div>
  )}

  <!-- Top movers -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-6">
    <div data-panel="producers">
      <Panel title="TOP PRODUCERS · 30m" raised noPadding>
        <div class="divide-y divide-mc-cobble/50">
          {(() => {
            const producers = velocity.filter(v => v.delta > 0);
            const max = producers[0]?.delta ?? 1;
            return producers.length > 0
              ? producers.slice(0, 8).map(v => {
                  const pct = Math.min(100, (v.delta / max) * 100);
                  return (
                    <div class="px-4 py-2 flex flex-col gap-1">
                      <div class="flex items-center justify-between">
                        <span class="font-mc text-xs text-mc-white capitalize">{itemLabel(v.item)}</span>
                        <span class="font-mc text-xs text-mc-emerald">+{fmt(v.delta)}</span>
                      </div>
                      <div class="mc-progress-track">
                        <div class="mc-progress-fill" style={`width:${pct}%;background-color:var(--color-mc-emerald);opacity:0.6`} />
                      </div>
                    </div>
                  );
                })
              : <p class="font-mc text-xs text-mc-muted px-4 py-4">No production detected</p>;
          })()}
        </div>
      </Panel>
    </div>

    <div data-panel="consumers">
      <Panel title="TOP CONSUMERS · 30m" raised noPadding>
        <div class="divide-y divide-mc-cobble/50">
          {(() => {
            const consumers = velocity.filter(v => v.delta < 0);
            const max = Math.abs(consumers[0]?.delta ?? 1);
            return consumers.length > 0
              ? consumers.slice(0, 8).map(v => {
                  const pct = Math.min(100, (Math.abs(v.delta) / max) * 100);
                  return (
                    <div class="px-4 py-2 flex flex-col gap-1">
                      <div class="flex items-center justify-between">
                        <span class="font-mc text-xs text-mc-white capitalize">{itemLabel(v.item)}</span>
                        <span class="font-mc text-xs text-mc-redstone">{fmt(v.delta)}</span>
                      </div>
                      <div class="mc-progress-track">
                        <div class="mc-progress-fill" style={`width:${pct}%;background-color:var(--color-mc-redstone);opacity:0.6`} />
                      </div>
                    </div>
                  );
                })
              : <p class="font-mc text-xs text-mc-muted px-4 py-4">No consumption detected</p>;
          })()}
        </div>
      </Panel>
    </div>
  </div>

  <!-- Item list -->
  <Panel title="ITEMS" raised noPadding>
    <div id="item-list" class="divide-y divide-mc-cobble/50">
      {items.map(item => (
        <div
          class="flex items-center justify-between px-4 py-2 hover:bg-mc-stone/20 transition-colors cursor-pointer item-row"
          data-item={item.item}
        >
          <div class="flex flex-col gap-0.5">
            <span class="font-mc text-xs text-mc-white capitalize">{itemLabel(item.item)}</span>
            <span class="font-mc text-xs text-mc-muted">{item.item}</span>
          </div>
          <span class="font-mc text-sm text-mc-diamond shrink-0">{fmt(item.count)}</span>
        </div>
      ))}
      {items.length === 0 && (
        <p class="font-mc text-xs text-mc-muted px-4 py-6">No items found</p>
      )}
    </div>
  </Panel>
  </div>

  <!-- Tab: Fluids -->
  <div id="tab-fluids" class="hidden">
    <!-- Fluid stats -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-6">
      <StatCard label="Total Fluids" value={fmtMb(totalFluids)} colour="lapis" id="stat-total-fluids" />
      <StatCard label="Unique Types" value={fluids.length} colour="lapis" id="stat-unique-fluids" />
    </div>

    <!-- Fluid velocity panels -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-6">
      <div data-panel="fluid-producers">
        <Panel title="TOP PRODUCERS · 30m" raised noPadding>
          <div class="divide-y divide-mc-cobble/50">
            {(() => {
              const producers = fluidVelocity.filter(v => v.delta > 0);
              const max = producers[0]?.delta ?? 1;
              return producers.length > 0
                ? producers.slice(0, 8).map(v => {
                    const pct = Math.min(100, (v.delta / max) * 100);
                    return (
                      <div class="px-4 py-2 flex flex-col gap-1">
                        <div class="flex items-center justify-between">
                          <span class="font-mc text-xs text-mc-white capitalize">{itemLabel(v.item)}</span>
                          <span class="font-mc text-xs text-mc-emerald">+{fmtMb(v.delta)}</span>
                        </div>
                        <div class="mc-progress-track">
                          <div class="mc-progress-fill" style={`width:${pct}%;background-color:var(--color-mc-emerald);opacity:0.6`} />
                        </div>
                      </div>
                    );
                  })
                : <p class="font-mc text-xs text-mc-muted px-4 py-4">No production detected</p>;
            })()}
          </div>
        </Panel>
      </div>

      <div data-panel="fluid-consumers">
        <Panel title="TOP CONSUMERS · 30m" raised noPadding>
          <div class="divide-y divide-mc-cobble/50">
            {(() => {
              const consumers = fluidVelocity.filter(v => v.delta < 0);
              const max = Math.abs(consumers[0]?.delta ?? 1);
              return consumers.length > 0
                ? consumers.slice(0, 8).map(v => {
                    const pct = Math.min(100, (Math.abs(v.delta) / max) * 100);
                    return (
                      <div class="px-4 py-2 flex flex-col gap-1">
                        <div class="flex items-center justify-between">
                          <span class="font-mc text-xs text-mc-white capitalize">{itemLabel(v.item)}</span>
                          <span class="font-mc text-xs text-mc-redstone">{fmtMb(v.delta)}</span>
                        </div>
                        <div class="mc-progress-track">
                          <div class="mc-progress-fill" style={`width:${pct}%;background-color:var(--color-mc-redstone);opacity:0.6`} />
                        </div>
                      </div>
                    );
                  })
                : <p class="font-mc text-xs text-mc-muted px-4 py-4">No consumption detected</p>;
            })()}
          </div>
        </Panel>
      </div>
    </div>

    <!-- Fluid list -->
    <Panel title="FLUIDS" raised noPadding>
      <div id="fluid-list" class="divide-y divide-mc-cobble/50">
        {fluids.map(fluid => (
          <div
            class="flex items-center justify-between px-4 py-2 hover:bg-mc-stone/20 transition-colors cursor-pointer fluid-row"
            data-fluid={fluid.fluid}
          >
            <div class="flex flex-col gap-0.5">
              <span class="font-mc text-xs text-mc-white capitalize">{itemLabel(fluid.fluid)}</span>
              <span class="font-mc text-xs text-mc-muted">{fluid.fluid}</span>
            </div>
            <span class="font-mc text-sm text-mc-lapis shrink-0">{fmtMb(fluid.amount)}</span>
          </div>
        ))}
        {fluids.length === 0 && (
          <p class="font-mc text-xs text-mc-muted px-4 py-6">No fluids found</p>
        )}
      </div>
    </Panel>
  </div>

  <!-- Tab: Chemicals -->
  <div id="tab-chemicals" class="hidden">
    <!-- Chemical stats -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-6">
      <StatCard label="Total Chemicals" value={fmtMb(totalChemicals)} colour="amethyst" id="stat-total-chemicals" />
      <StatCard label="Unique Types" value={chemicals.length} colour="amethyst" id="stat-unique-chemicals" />
    </div>

    <!-- Chemical velocity panels -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-6">
      <div data-panel="chemical-producers">
        <Panel title="TOP PRODUCERS · 30m" raised noPadding>
          <div class="divide-y divide-mc-cobble/50">
            {(() => {
              const producers = chemVelocity.filter(v => v.delta > 0);
              const max = producers[0]?.delta ?? 1;
              return producers.length > 0
                ? producers.slice(0, 8).map(v => {
                    const pct = Math.min(100, (v.delta / max) * 100);
                    return (
                      <div class="px-4 py-2 flex flex-col gap-1">
                        <div class="flex items-center justify-between">
                          <span class="font-mc text-xs text-mc-white capitalize">{itemLabel(v.item)}</span>
                          <span class="font-mc text-xs text-mc-emerald">+{fmtMb(v.delta)}</span>
                        </div>
                        <div class="mc-progress-track">
                          <div class="mc-progress-fill" style={`width:${pct}%;background-color:var(--color-mc-emerald);opacity:0.6`} />
                        </div>
                      </div>
                    );
                  })
                : <p class="font-mc text-xs text-mc-muted px-4 py-4">No production detected</p>;
            })()}
          </div>
        </Panel>
      </div>

      <div data-panel="chemical-consumers">
        <Panel title="TOP CONSUMERS · 30m" raised noPadding>
          <div class="divide-y divide-mc-cobble/50">
            {(() => {
              const consumers = chemVelocity.filter(v => v.delta < 0);
              const max = Math.abs(consumers[0]?.delta ?? 1);
              return consumers.length > 0
                ? consumers.slice(0, 8).map(v => {
                    const pct = Math.min(100, (Math.abs(v.delta) / max) * 100);
                    return (
                      <div class="px-4 py-2 flex flex-col gap-1">
                        <div class="flex items-center justify-between">
                          <span class="font-mc text-xs text-mc-white capitalize">{itemLabel(v.item)}</span>
                          <span class="font-mc text-xs text-mc-redstone">{fmtMb(v.delta)}</span>
                        </div>
                        <div class="mc-progress-track">
                          <div class="mc-progress-fill" style={`width:${pct}%;background-color:var(--color-mc-redstone);opacity:0.6`} />
                        </div>
                      </div>
                    );
                  })
                : <p class="font-mc text-xs text-mc-muted px-4 py-4">No consumption detected</p>;
            })()}
          </div>
        </Panel>
      </div>
    </div>

    <!-- Chemical list -->
    <Panel title="CHEMICALS" raised noPadding>
      <div id="chemical-list" class="divide-y divide-mc-cobble/50">
        {chemicals.map(chemical => (
          <div
            class="flex items-center justify-between px-4 py-2 hover:bg-mc-stone/20 transition-colors cursor-pointer chemical-row"
            data-chemical={chemical.chemical}
          >
            <div class="flex flex-col gap-0.5">
              <span class="font-mc text-xs text-mc-white capitalize">{itemLabel(chemical.chemical)}</span>
              <span class="font-mc text-xs text-mc-muted">{chemical.chemical}</span>
            </div>
            <span class="font-mc text-sm text-mc-amethyst shrink-0">{fmtMb(chemical.amount)}</span>
          </div>
        ))}
        {chemicals.length === 0 && (
          <p class="font-mc text-xs text-mc-muted px-4 py-6">No chemicals found</p>
        )}
      </div>
    </Panel>
  </div>
</Layout>

<script>
  const REFRESH_MS = 60_000;
  let currentQuery = '';
  let sortMode: 'count' | 'name' = 'count';
  let sortDir: 'desc' | 'asc' = 'desc';
  let allItems: { item: string; count: number }[] = [];
  let allFluids: { fluid: string; amount: number }[] = [];
  let allChemicals: { chemical: string; amount: number }[] = [];
  let currentTab: 'items' | 'fluids' | 'chemicals' = 'items';

  function itemLabel(name: string): string {
    return name.replace(/^.*:/, '').replace(/_/g, ' ');
  }

  function fmt(n: number): string {
    if (n >= 1_000_000) return (n / 1_000_000).toFixed(2) + 'M';
    if (n >= 1_000) return (n / 1_000).toFixed(1) + 'K';
    return n.toLocaleString();
  }

  function fmtMb(n: number): string {
    if (n >= 1_000_000) return (n / 1_000_000).toFixed(2) + 'M mB';
    if (n >= 1_000) return (n / 1_000).toFixed(1) + 'K mB';
    return n.toLocaleString() + ' mB';
  }

  // Tab switching
  function switchTab(tab: 'items' | 'fluids' | 'chemicals') {
    currentTab = tab;
    document.querySelectorAll('.tab-btn').forEach(btn => {
      if (btn.getAttribute('data-tab') === tab) {
        btn.className = 'tab-btn mc-slot px-4 py-2 font-mc text-xs text-mc-diamond';
      } else {
        btn.className = 'tab-btn mc-slot px-4 py-2 font-mc text-xs text-mc-muted';
      }
    });
    document.getElementById('tab-items')?.classList.toggle('hidden', tab !== 'items');
    document.getElementById('tab-fluids')?.classList.toggle('hidden', tab !== 'fluids');
    document.getElementById('tab-chemicals')?.classList.toggle('hidden', tab !== 'chemicals');
    document.querySelectorAll('.history-panel').forEach(el => el.remove());
  }

  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const tab = btn.getAttribute('data-tab') as 'items' | 'fluids' | 'chemicals';
      if (tab) switchTab(tab);
    });
  });

  function sortItems(items: { item: string; count: number }[]) {
    const copy = [...items];
    if (sortMode === 'name') {
      copy.sort((a, b) => {
        const cmp = itemLabel(a.item).localeCompare(itemLabel(b.item));
        return sortDir === 'asc' ? cmp : -cmp;
      });
    } else {
      copy.sort((a, b) => sortDir === 'desc' ? b.count - a.count : a.count - b.count);
    }
    return copy;
  }

  function sortFluids(fluids: { fluid: string; amount: number }[]) {
    const copy = [...fluids];
    if (sortMode === 'name') {
      copy.sort((a, b) => {
        const cmp = itemLabel(a.fluid).localeCompare(itemLabel(b.fluid));
        return sortDir === 'asc' ? cmp : -cmp;
      });
    } else {
      copy.sort((a, b) => sortDir === 'desc' ? b.amount - a.amount : a.amount - b.amount);
    }
    return copy;
  }

  function sortChemicals(chemicals: { chemical: string; amount: number }[]) {
    const copy = [...chemicals];
    if (sortMode === 'name') {
      copy.sort((a, b) => {
        const cmp = itemLabel(a.chemical).localeCompare(itemLabel(b.chemical));
        return sortDir === 'asc' ? cmp : -cmp;
      });
    } else {
      copy.sort((a, b) => sortDir === 'desc' ? b.amount - a.amount : a.amount - b.amount);
    }
    return copy;
  }

  function updateSortButtons() {
    const btnCount = document.getElementById('sort-count');
    const btnName = document.getElementById('sort-name');
    if (btnCount) {
      const arrow = sortMode === 'count' ? (sortDir === 'desc' ? ' ▼' : ' ▲') : '';
      btnCount.textContent = 'COUNT' + arrow;
      btnCount.className = `mc-slot px-3 py-1.5 font-mc text-xs ${sortMode === 'count' ? 'text-mc-diamond' : 'text-mc-muted'}`;
    }
    if (btnName) {
      const arrow = sortMode === 'name' ? (sortDir === 'asc' ? ' ▲' : ' ▼') : '';
      btnName.textContent = 'NAME' + arrow;
      btnName.className = `mc-slot px-3 py-1.5 font-mc text-xs ${sortMode === 'name' ? 'text-mc-diamond' : 'text-mc-muted'}`;
    }
  }

  function renderSparkline(container: HTMLElement, points: {time: string; value: number}[], colour: string) {
    if (points.length < 2) {
      container.innerHTML = '<p class="font-mc text-[9px] text-mc-muted">Not enough data</p>';
      return;
    }
    const W = container.clientWidth || 400;
    const H = container.clientHeight || 96;
    const pad = 4;
    const min = Math.min(...points.map(p => p.value));
    const max = Math.max(...points.map(p => p.value));
    const range = max - min || 1;
    const xs = points.map((_, i) => pad + (i / (points.length - 1)) * (W - pad * 2));
    const ys = points.map(p => H - pad - ((p.value - min) / range) * (H - pad * 2));
    const d = xs.map((x, i) => `${i === 0 ? 'M' : 'L'}${x.toFixed(1)},${ys[i]!.toFixed(1)}`).join(' ');
    const fillD = `${d} L${xs[xs.length-1]!.toFixed(1)},${H} L${xs[0]!.toFixed(1)},${H} Z`;
    const colourVar = `var(--color-mc-${colour})`;
    container.innerHTML = `
      <svg width="100%" height="100%" viewBox="0 0 ${W} ${H}" preserveAspectRatio="none">
        <path d="${fillD}" fill="${colourVar}" opacity="0.15"/>
        <path d="${d}" fill="none" stroke="${colourVar}" stroke-width="1.5" opacity="0.9"/>
      </svg>`;
  }

  function fmtChartVal(v: number): string {
    const abs = Math.abs(v);
    if (abs >= 1_000_000_000) return (v / 1_000_000_000).toFixed(1) + 'B';
    if (abs >= 1_000_000) return (v / 1_000_000).toFixed(1) + 'M';
    if (abs >= 1_000) return (v / 1_000).toFixed(1) + 'K';
    return v.toFixed(1);
  }

  function renderSvgLine(containerId: string, points: {time:string;value:number}[], colour: string, suffix = '') {
    const el = document.getElementById(containerId);
    if (!el || points.length < 2) return;
    const existingSvg = el.querySelector('svg');
    const H = existingSvg ? (parseInt(existingSvg.getAttribute('height') ?? '') || 80) : 80;
    const W = 400, pad = 6;
    const vals = points.map(p => p.value);
    const minV = Math.min(...vals), maxV = Math.max(...vals);
    const vRange = maxV - minV || 1;
    const xs = points.map((_, i) => pad + (i / (points.length - 1)) * (W - pad * 2));
    const ys = points.map(p => H - pad - ((p.value - minV) / vRange) * (H - pad * 2));
    const d = xs.map((x, i) => `${i === 0 ? 'M' : 'L'}${x.toFixed(1)},${ys[i]!.toFixed(1)}`).join(' ');
    const fillD = `${d} L${xs[xs.length-1]!.toFixed(1)},${H} L${xs[0]!.toFixed(1)},${H} Z`;
    const svg = `<svg width="100%" height="${H}" viewBox="0 0 ${W} ${H}" preserveAspectRatio="none" style="height:${H}px">
      <path d="${fillD}" fill="${colour}" opacity="0.15"/>
      <path d="${d}" fill="none" stroke="${colour}" stroke-width="1.5" opacity="0.9"/>
    </svg>`;
    if (existingSvg) existingSvg.outerHTML = svg;
    else el.insertAdjacentHTML('afterbegin', svg);
    // Update labels row
    const labelsRow = el.querySelector('div.flex.justify-between');
    if (labelsRow) {
      const spans = labelsRow.querySelectorAll('span');
      if (spans.length >= 3) {
        spans[0]!.textContent = fmtChartVal(minV) + suffix;
        spans[1]!.textContent = fmtChartVal(vals[vals.length - 1]!) + suffix;
        spans[2]!.textContent = fmtChartVal(maxV) + suffix;
      }
    }
  }

  async function showHistory(type: 'item' | 'fluid' | 'chemical', id: string, row: HTMLElement, colour: string) {
    const existing = row.nextElementSibling;
    if (existing?.classList.contains('history-panel')) {
      existing.remove();
      return;
    }

    document.querySelectorAll('.history-panel').forEach(el => el.remove());

    const panel = document.createElement('div');
    panel.className = 'history-panel px-4 py-3 bg-mc-obsidian/50 border-t border-mc-cobble/30';
    panel.innerHTML = `
      <div class="flex items-center gap-2 mb-2">
        <span class="font-mc text-[9px] text-mc-muted">RANGE:</span>
        <button data-range="-1h"  class="range-btn mc-slot px-2 py-0.5 font-mc text-[9px] text-mc-diamond">1H</button>
        <button data-range="-6h"  class="range-btn mc-slot px-2 py-0.5 font-mc text-[9px] text-mc-muted">6H</button>
        <button data-range="-24h" class="range-btn mc-slot px-2 py-0.5 font-mc text-[9px] text-mc-muted">24H</button>
        <button data-range="-7d"  class="range-btn mc-slot px-2 py-0.5 font-mc text-[9px] text-mc-muted">7D</button>
        <button data-range="-14d" class="range-btn mc-slot px-2 py-0.5 font-mc text-[9px] text-mc-muted">14D</button>
        <button data-range="-21d" class="range-btn mc-slot px-2 py-0.5 font-mc text-[9px] text-mc-muted">21D</button>
        <button data-range="-31d" class="range-btn mc-slot px-2 py-0.5 font-mc text-[9px] text-mc-muted">31D</button>
        <span class="font-mc text-[9px] text-mc-muted ml-auto history-label">Loading...</span>
      </div>
      <div class="history-chart-container h-24 w-full"></div>`;
    
    row.after(panel);

    async function loadHistoryData(range: string) {
      let url = '';
      if (type === 'item') url = `/api/ae-items?item=${encodeURIComponent(id)}&range=${range}`;
      else if (type === 'fluid') url = `/api/fluids?history=${encodeURIComponent(id)}&range=${range}`;
      else if (type === 'chemical') url = `/api/chemicals?history=${encodeURIComponent(id)}&range=${range}`;
      
      const data = await fetch(url).then(r => r.json()).catch(() => ({ history: [] }));
      const container = panel.querySelector('.history-chart-container') as HTMLElement;
      const label = panel.querySelector('.history-label') as HTMLElement;
      if (container) renderSparkline(container, data.history || [], colour);
      if (label) label.textContent = itemLabel(id);
    }

    panel.querySelectorAll('.range-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        panel.querySelectorAll('.range-btn').forEach(b => {
          b.className = 'range-btn mc-slot px-2 py-0.5 font-mc text-[9px] text-mc-muted';
        });
        btn.className = 'range-btn mc-slot px-2 py-0.5 font-mc text-[9px] text-mc-diamond';
        await loadHistoryData(btn.getAttribute('data-range') || '-1h');
      });
    });

    await loadHistoryData('-1h');
  }

  function renderItems(items: { item: string; count: number }[]) {
    const list = document.getElementById('item-list');
    if (!list) return;
    const sorted = sortItems(items);
    list.innerHTML = sorted.length === 0
      ? '<p class="font-mc text-xs text-mc-muted px-4 py-6">No items found</p>'
      : sorted.map(i => `
        <div class="flex items-center justify-between px-4 py-2 hover:bg-mc-stone/20 transition-colors cursor-pointer item-row" data-item="${i.item}">
          <div class="flex flex-col gap-0.5">
            <span class="font-mc text-xs text-mc-white capitalize">${itemLabel(i.item)}</span>
            <span class="font-mc text-xs text-mc-muted">${i.item}</span>
          </div>
          <span class="font-mc text-sm text-mc-diamond">${fmt(i.count)}</span>
        </div>
      `).join('');
    
    list.querySelectorAll('.item-row').forEach(row => {
      row.addEventListener('click', () => {
        const item = row.getAttribute('data-item');
        if (item) showHistory('item', item, row as HTMLElement, 'diamond');
      });
    });
  }

  function renderFluids(fluids: { fluid: string; amount: number }[]) {
    const list = document.getElementById('fluid-list');
    if (!list) return;
    const sorted = sortFluids(fluids);
    list.innerHTML = sorted.length === 0
      ? '<p class="font-mc text-xs text-mc-muted px-4 py-6">No fluids found</p>'
