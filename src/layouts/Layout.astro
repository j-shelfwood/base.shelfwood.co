---
import '@/styles/site.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'MC Base — Shelfwood',
  description = 'Minecraft CC:Tweaked telemetry dashboard',
} = Astro.props;

const navLinks = [
  { href: '/#overview',  label: 'Overview',  section: 'overview'  },
  { href: '/#machines',  label: 'Machines',  section: 'machines'  },
  { href: '/#storage',   label: 'Storage',   section: 'storage'   },
  { href: '/#crafting',  label: 'Crafting',  section: 'crafting'  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Top navigation bar -->
    <nav class="mc-panel-raised border-b-2 border-mc-cobble sticky top-0 z-50">
      <div class="px-4 flex items-center gap-1 h-12">
        <!-- Logo -->
        <a href="/" class="font-mc text-mc-diamond text-sm glow-diamond mr-6 shrink-0">
          ⚡ MC BASE
        </a>

        <!-- Nav links — active state driven by IntersectionObserver in scroll-nav script -->
        {navLinks.map(link => (
          <a
            href={link.href}
            data-section={link.section}
            class="nav-link font-mc text-xs px-3 py-1.5 transition-colors text-mc-muted hover:text-mc-white hover:bg-mc-stone/40"
          >
            {link.label}
          </a>
        ))}

        <!-- Live indicator -->
        <div class="ml-auto flex items-center gap-2">
          <span id="live-dot" class="w-2 h-2 rounded-none bg-mc-emerald animate-pulse"></span>
          <span id="live-label" class="font-mc text-xs text-mc-muted">LIVE</span>
        </div>
      </div>
    </nav>

    <!-- Main content -->
    <main class="flex-1 w-full px-4 py-6">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t-2 border-mc-cobble px-4 py-3">
      <div class="flex items-center justify-between">
        <span class="font-mc text-xs text-mc-muted">CC:TWEAKED TELEMETRY</span>
        <span class="font-mc text-xs text-mc-stone" id="last-updated"></span>
      </div>
    </footer>

    <script>
      // Highlight nav link matching the section currently in view
      const sections = document.querySelectorAll('section[id]');
      const navLinks = document.querySelectorAll('a.nav-link[data-section]');

      if (sections.length > 0) {
        const observer = new IntersectionObserver(entries => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              const id = entry.target.id;
              for (const link of navLinks) {
                const active = (link as HTMLElement).dataset.section === id;
                link.className = active
                  ? 'nav-link font-mc text-xs px-3 py-1.5 transition-colors mc-slot text-mc-white'
                  : 'nav-link font-mc text-xs px-3 py-1.5 transition-colors text-mc-muted hover:text-mc-white hover:bg-mc-stone/40';
              }
            }
          }
        }, { rootMargin: '-40% 0px -55% 0px' });

        sections.forEach(s => observer.observe(s));
      }

      // Smooth scroll for anchor links
      document.querySelectorAll('a[href^="/#"]').forEach(a => {
        a.addEventListener('click', e => {
          const id = (a.getAttribute('href') ?? '').replace('/#', '');
          const target = document.getElementById(id);
          if (target) {
            e.preventDefault();
            target.scrollIntoView({ behavior: 'smooth' });
          }
        });
      });
    </script>
  </body>
</html>
